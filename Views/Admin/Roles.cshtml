@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Roller - Admin";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <h1 class="hero-title">🔐 Roller</h1>
        <p class="text-muted">Sistemde tanımlı roller</p>
    </div>

    <div class="mb-3">
        <a href="@Url.Action("CreateRole", "Admin")" class="btn btn-primary">Yeni Rol Oluştur</a>
        <a href="@Url.Action("Users", "Admin")" class="btn btn-outline-secondary">Üye Listesine Dön</a>
    </div>

    <div class="card-custom">
        <div class="table-responsive">
            <table class="table table-dark table-striped mb-0">
            <thead>
                <tr>
                    <th>Rol Adı</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td>@role.Name</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>