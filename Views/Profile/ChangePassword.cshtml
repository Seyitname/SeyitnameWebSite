@model ChangePasswordModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}

<!-- Şifre değiştirme sayfası -->
<div class="form-page-bg">
    <div class="form-page-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-6">
                    <div class="card-custom shadow-lg">
                        <div class="card-body p-5">
                            <h2 class="card-title text-center gradient-text mb-4">Şifre Değiştir</h2>

                            @if (TempData["Success"] != null)
                            {
                                <div class="alert alert-success mb-4">
                                    @TempData["Success"]
                                </div>
                            }

                            <form asp-action="ChangePassword" method="post">
                                <div class="form-group mb-3">
                                    <label asp-for="CurrentPassword" class="form-label gradient-text">🔐 Mevcut Şifre</label>
                                    <input asp-for="CurrentPassword" type="password" class="form-control-custom form-control" placeholder="Mevcut şifreniz" />
                                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="NewPassword" class="form-label gradient-text">🔐 Yeni Şifre</label>
                                    <input asp-for="NewPassword" type="password" class="form-control-custom form-control" placeholder="Yeni şifre (En az 6 karakter)" />
                                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="ConfirmNewPassword" class="form-label gradient-text">🔐 Yeni Şifre Onayı</label>
                                    <input asp-for="ConfirmNewPassword" type="password" class="form-control-custom form-control" placeholder="Yeni şifreyi onaylayın" />
                                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                                </div>

                                <button type="submit" class="btn btn-custom w-100 mb-3">Şifre Değiştir</button>
                            </form>

                            <div class="text-center">
                                <a asp-action="Index" class="gradient-text text-decoration-none">← Profile Dön</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}