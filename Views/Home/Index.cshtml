@model IEnumerable<Baglanti>
@{
    ViewData["Title"] = "Anasayfa - Seyitname";
}

<!-- AI tarafından yapıldı - Landing page ve rastgele bağlantılar -->

<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">Hoşgeldiniz!</h1>
        <p class="hero-subtitle">Seyitname - Kişisel Portföy ve İletişim Platformu</p>
        
        <div class="mt-5 d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Baglanti/Index" class="btn btn-outline-primary btn-lg text-white">
                📁 Portföyümü Gör
            </a>
            <a href="/CallUs/Index" class="btn btn-outline-primary btn-lg text-white">
                💬 İletişime Geç
            </a>
        </div>

        <div class="mt-5">
            <p class="text-muted small">
                <i class="fas fa-arrow-down"></i> Aşağı Scroll Edin
            </p>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <!-- Özellikler -->
        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="card-custom portfolio-item">
                    <h3 class="gradient-text mb-3">🎯 Hakkımda</h3>
                    <p class="text-muted">
                        Bu sayfada kişisel bilgilerim, portföyüm ve iletişim bilgilerim yer almaktadır. 
                        Portföy sayfasında projelerim ve bağlantılarım bulunmaktadır.
                    </p>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card-custom portfolio-item">
                    <h3 class="gradient-text mb-3">📱 İletişim</h3>
                    <p class="text-muted">
                        Herhangi bir sorunuz veya öneriniz varsa lütfen iletişim formunu kullanarak bize ulaşabilirsiniz. 
                        Geri dönüşlere çok değer veriyoruz.
                    </p>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card-custom portfolio-item text-center">
                    <h4 class="gradient-text mb-2">💻</h4>
                    <h5>Profiller</h5>
                    <p class="text-muted small">Profillerimi görüntüleyin</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-custom portfolio-item text-center">
                    <h4 class="gradient-text mb-2">📚</h4>
                    <h5>Bilgiler</h5>
                    <p class="text-muted small">Kişisel bilgilerim ve detaylı bilgiler</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-custom portfolio-item text-center">
                    <h4 class="gradient-text mb-2">🔗</h4>
                    <h5>Bağlantılar</h5>
                    <p class="text-muted small">Sosyal medya ve diğer bağlantılar</p>
                </div>
            </div>
        </div>

        <!-- Rastgele 3 Bağlantı -->
        @if (Model != null && Model.Any())
        {
            <div class="text-center mb-5 portfolio-item">
                <h2 class="gradient-text mb-1">✨ Spotlight</h2>
                <p class="text-muted">Rastgele Seçilen Profillerim</p>
            </div>

            <div class="row g-4">
                @foreach (var baglanti in Model)
                {
                    <div class="col-md-6 col-lg-4 portfolio-item">
                        <div class="card-custom h-100 d-flex flex-column">
                            @if (!string.IsNullOrEmpty(baglanti.Picture))
                            {
                                <div class="mb-3" style="overflow: hidden; border-radius: 10px; height: 150px;">
                                    <img src="~/img/@baglanti.Picture" class="img-fluid w-100 h-100" style="object-fit: cover; transition: transform 0.3s ease;" alt="@baglanti.Name">
                                </div>
                            }
                            <h4 class="gradient-text mb-2">@baglanti.Name</h4>
                            <p class="text-muted small mb-3 flex-grow-1">@baglanti.Description</p>
                            <div class="d-flex gap-2">
                                @if (!string.IsNullOrEmpty(baglanti.Link))
                                {
                                    <a href="@baglanti.Link" target="_blank" class="btn btn-custom btn-sm flex-grow-1">
                                        🔗 Ziyaret Et
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a href="/Baglanti/Index" class="btn btn-outline-primary btn-lg">
                    Tüm Portföyü Gör →
                </a>
            </div>
        }
    </div>
</section>

