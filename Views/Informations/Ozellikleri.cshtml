<!-- AI tarafından yapıldı - Modernize informations sayfası -->
@{
    ViewData["Title"] = "Özellikleri - Seyitname";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-5 portfolio-item">
                <h1 class="hero-title mb-3">✨ Seyitname'nin Özellikleri</h1>
                <p class="hero-subtitle">Temel Nitelikleri</p>
            </div>

            <div class="card-custom portfolio-item">
                <h3 class="gradient-text mb-4">Tanınırlığı</h3>
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3" style="background: rgba(102, 126, 234, 0.1); border-radius: 8px;">
                            <h6 class="gradient-text mb-2">📜 Eski</h6>
                            <p class="text-muted small mb-0">Çok eski ve köklü bir nickname'dir</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3" style="background: rgba(240, 147, 251, 0.1); border-radius: 8px;">
                            <h6 class="gradient-text mb-2\">🎮 Popüler</h6>
                            <p class="text-muted small mb-0\">Birçok oyunda ve platformda kullanılmıştır</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3" style="background: rgba(102, 126, 234, 0.1); border-radius: 8px;">
                            <h6 class="gradient-text mb-2">👥 Tanınır</h6>
                            <p class="text-muted small mb-0">Oyun topluluklarında çok tanınır</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3" style="background: rgba(240, 147, 251, 0.1); border-radius: 8px;">
                            <h6 class="gradient-text mb-2">⭐ Ünlü</h6>
                            <p class="text-muted small mb-0">Instagram ve Facebook'da çalınmıştır</p>
                        </div>
                    </div>
                </div>

                <div class="mt-4 p-4" style="background: rgba(102, 126, 234, 0.05); border-radius: 8px; border-left: 3px solid var(--primary-color);">
                    <h5 class="gradient-text mb-3">Bulunduğu Platformlar</h5>
                    <ul class="text-muted small mb-0">
                        <li>✓ Çeşitli oyunlarda aktif</li>
                        <li>✓ Sosyal medya platformlarında popüler</li>
                        <li>✓ İnternet topluluklarında tanınır</li>
                        <li>✓ Web geliştirme alanında çalışıyor</li>
                    </ul>
                </div>
            </div>

            <div class="text-center mt-5">
                <a href="/Informations/Anlami" class="btn btn-outline-primary\ text-white">← Anlamı</a>
                <a href="/Home/Index" class="btn btn-outline-primary\ text-white">Anasayfaya Dön →</a>
            </div>
        </div>
    </div>
</div>