<!-- AI tarafından yapıldı - Portföy sayfası -->
@model IEnumerable<Baglanti>
@{
    ViewData["Title"] = "Portföy - Seyitname";
}

<div class="container py-5">
    <div class="text-center mb-5 portfolio-item">
        <h1 class="hero-title mb-3">📁 Portföyüm</h1>
        <p class="hero-subtitle">Projelerim, Çalışmalarım ve Bağlantılarım</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var baglanti in Model)
            {
                <div class="col-md-6 col-lg-4 portfolio-item">
                    <div class="card-custom h-100 d-flex flex-column">
                        @if (!string.IsNullOrEmpty(baglanti.Picture))
                        {
                            <div class="mb-3" style="overflow: hidden; border-radius: 10px; height: 180px;">
                                <img src="~/img/@baglanti.Picture" class="img-fluid w-100 h-100" style="object-fit: cover; transition: transform 0.3s ease;" alt="@baglanti.Name">
                            </div>
                        }
                        <h4 class="gradient-text mb-2">@baglanti.Name</h4>
                        <p class="text-muted small mb-3 flex-grow-1">@baglanti.Description</p>
                        <div class="d-flex gap-2">
                            @if (!string.IsNullOrEmpty(baglanti.Link))
                            {
                                <a href="@baglanti.Link" target="_blank" class="btn btn-custom btn-sm flex-grow-1">🔗 Ziyaret Et</a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <div class="card-custom">
                    <h4 class="text-muted">Henüz portföy öğesi eklenmemiş</h4>
                </div>
            </div>
        }
    </div>
</div>

